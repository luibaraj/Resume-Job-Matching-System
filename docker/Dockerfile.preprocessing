FROM python:3.11-slim

# Non-root user for security
RUN useradd -m -u 1000 pipeline

WORKDIR /app

# Preprocessing has zero third-party dependencies — all stdlib
# (html, re, sqlite3 are all built-in)
# Uses only standard library, no additional packages needed

COPY src/config.py src/database.py src/utils.py src/preprocessing.py src/

USER pipeline

ENTRYPOINT ["python", "-m", "src.preprocessing"]

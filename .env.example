# SQLite database path — must match Docker bind mount
DB_PATH=/data/jobs.db

# HTTP settings
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_BACKOFF=2.0

# Logging
LOG_LEVEL=INFO

# --- Airflow Variables (set in Airflow UI: Admin > Variables) ---
# GREENHOUSE_BOARD_TOKENS must also be set as an Airflow Variable
# DATA_HOST_PATH: Absolute host path to the ./data directory. Set this in the Airflow UI too (Admin > Variables)
DATA_HOST_PATH=/absolute/path/to/repo/data
COLLECTION_IMAGE=job-collection:latest
PREPROCESSING_IMAGE=job-preprocessing:latest
